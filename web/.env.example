# Copy to .env.local for local dev. Never commit real values.
# In production these are set as Railway environment variables.

# next-auth v4 with Azure AD SSO. SSO is the only auth path.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Worker service base URL (Python worker on Railway). The API layer submits
# jobs and reads results from here.
WORKER_BASE_URL=http://localhost:8000

# Postgres with PostGIS. The web app reads catchments and battlecards.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/landlynk
